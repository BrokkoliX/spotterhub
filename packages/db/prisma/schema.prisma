// ─── SpotterHub Database Schema ──────────────────────────────────────────────
// PostgreSQL 16 + PostGIS extension
// Phase 1a tables are fully defined; Phase 1b tables are schema-only placeholders.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets    = ["native", "linux-arm64-openssl-3.0.x", "rhel-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, pg_trgm]
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  user
  moderator
  admin
  superuser
}

enum UserStatus {
  active
  suspended
  banned
}

enum ExperienceLevel {
  beginner
  intermediate
  advanced
  professional
}

enum LocationPrivacyMode {
  exact
  approximate
  hidden
}

enum ModerationStatus {
  pending
  approved
  rejected
  review
}

enum PhotoLicense {
  ALL_RIGHTS_RESERVED
  CC_BY_NC_ND
  CC_BY_NC
  CC_BY_NC_SA
  CC_BY
  CC_BY_SA
}

enum SellerStatus {
  pending
  approved
  rejected
}

enum PhotoVariantType {
  thumbnail
  display
  full_res
  watermarked
}

enum NotificationType {
  like
  comment
  follow
  mention
  moderation
  system
  community_join
  community_event
}

enum ReportTargetType {
  photo
  comment
  profile
  album
}

enum ReportReason {
  inappropriate
  spam
  harassment
  copyright
  other
}

enum ReportStatus {
  open
  reviewed
  resolved
  dismissed
}

enum FollowTargetType {
  user
  airport
  manufacturer
  family
  variant
  airline
  registration
}

enum CommunityRole {
  owner
  admin
  moderator
  member
}

enum CommunityMemberStatus {
  active
  pending
  banned
}

enum CommunityVisibility {
  public
  invite_only
}

enum CommunityTier {
  free
  standard
  large
  enterprise
}

enum OperatorType {
  airline
  general_aviation
  military
  government
  cargo
  charter
  private
}

enum AircraftStatus {
  active
  pending_approval
}

enum OrderStatus {
  pending
  completed
  refunded
  failed
}

// ─── Aircraft Hierarchy ───────────────────────────────────────────────────────

model AircraftManufacturer {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  country   String?
  createdAt DateTime @default(now()) @map("created_at")

  families AircraftFamily[]
  aircraft Aircraft[] @relation("RegisteredAircraftManufacturer")

  @@map("aircraft_manufacturers")
}

model AircraftFamily {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @unique
  manufacturerId String  @map("manufacturer_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  manufacturer AircraftManufacturer @relation(fields: [manufacturerId], references: [id], onDelete: Cascade)
  variants     AircraftVariant[]
  aircraft     Aircraft[] @relation("RegisteredAircraftFamily")

  @@map("aircraft_families")
}

model AircraftVariant {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @unique
  familyId   String   @map("family_id") @db.Uuid
  iataCode   String?  @map("iata_code")
  icaoCode   String?  @map("icao_code")
  createdAt  DateTime @default(now()) @map("created_at")

  family   AircraftFamily @relation(fields: [familyId], references: [id], onDelete: Cascade)
  aircraft Aircraft[] @relation("RegisteredAircraftVariant")

  @@map("aircraft_variants")
}

model Airline {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  icaoCode  String?  @unique @map("icao_code")
  iataCode  String?  @unique @map("iata_code")
  country   String?
  callsign  String?  @map("callsign")
  createdAt DateTime @default(now()) @map("created_at")

  aircraft Aircraft[] @relation("RegisteredAirline")

  @@map("airlines")
}

model PhotoCategory {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  label     String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  photos Photo[]

  @@map("photo_categories")
}

model AircraftSpecificCategory {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  label     String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  photos Photo[]

  @@map("aircraft_specific_categories")
}

model PendingListItem {
  id          String   @id @default(uuid()) @db.Uuid
  listType    String
  value       String
  metadata    Json?
  submittedBy String   @map("submitted_by") @db.Uuid
  reviewedBy  String?  @map("reviewed_by") @db.Uuid
  status      String   @default("pending")
  reviewNote  String?  @map("review_note")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  submitter User  @relation("PendingListItemSubmitter", fields: [submittedBy], references: [id])
  reviewer  User? @relation("PendingListItemReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([submittedBy])
  @@index([reviewedBy])
  @@map("pending_list_items")
}

// ─── Phase 1a: Core Tables ───────────────────────────────────────────────────

model User {
  id                     String     @id @default(uuid()) @db.Uuid
  cognitoSub             String     @unique @map("cognito_sub")
  email                  String     @unique
  username               String     @unique
  role                   UserRole   @default(user)
  status                 UserStatus @default(active)
  emailVerified          Boolean    @default(false) @map("email_verified")
  emailVerificationToken String?    @map("email_verification_token")
  passwordHash           String?    @map("password_hash")
  createdAt              DateTime   @default(now()) @map("created_at")
  updatedAt              DateTime   @updatedAt @map("updated_at")

  profile            Profile?
  photos             Photo[]
  albums             Album[]
  comments           Comment[]
  likes              Like[]
  followers          Follow[]           @relation("Following")
  following          Follow[]           @relation("Follower")
  reports            Report[]           @relation("Reporter")
  reviewedReports    Report[]           @relation("Reviewer")
  notifications      Notification[]
  spottingLocations  SpottingLocation[]
  communityMembers   CommunityMember[]
  ownedCommunities   Community[]        @relation("CommunityOwner")
  forumThreads       ForumThread[]
  forumPosts         ForumPost[]
  organizedEvents    CommunityEvent[]  @relation("EventOrganizer")
  eventAttendances   EventAttendee[]
  moderationLogs     CommunityModerationLog[] @relation("Moderator")
  moderatedActions   CommunityModerationLog[] @relation("TargetUser")
  photographedPhotos  Photo[]           @relation("PhotoPhotographer")
  passwordResetTokens PasswordResetToken[]
  submittedPendingItems PendingListItem[] @relation("PendingListItemSubmitter")
  reviewedPendingItems PendingListItem[]  @relation("PendingListItemReviewer")
  refreshTokens     RefreshToken[]
  sellerProfile   SellerProfile?
  purchases       Order[]         @relation("BuyerOrders")
  sellerSales     Order[]         @relation("SellerSales")
  sellerListings  PhotoListing[]
  marketplaceItems MarketplaceItem[] @relation("SellerItems")
  sellerFeedback  SellerFeedback[] @relation("SellerReceivedFeedback")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique @map("token")
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Profile {
  id              String           @id @default(uuid()) @db.Uuid
  userId          String           @unique @map("user_id") @db.Uuid
  displayName     String?          @map("display_name")
  bio             String?
  avatarUrl       String?          @map("avatar_url")
  locationRegion  String?          @map("location_region")
  cameraBodies       String[] @default([]) @map("camera_bodies")
  lenses             String[] @default([]) @map("lenses")
  experienceLevel ExperienceLevel? @map("experience_level")
  gear            String?
  interests       String[]         @default([])
  favoriteAircraft String[]        @default([]) @map("favorite_aircraft")
  favoriteAirports String[]        @default([]) @map("favorite_airports")
  isPublic        Boolean          @default(true) @map("is_public")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Follow {
  id          String           @id @default(uuid()) @db.Uuid
  followerId  String           @map("follower_id") @db.Uuid
  targetType  FollowTargetType @map("target_type")
  followingId String?          @map("following_id") @db.Uuid
  airportId   String?          @map("airport_id") @db.Uuid
  targetValue String?          @map("target_value")
  createdAt   DateTime         @default(now()) @map("created_at")

  follower  User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User?    @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  airport   Airport? @relation(fields: [airportId], references: [id], onDelete: Cascade)

  @@unique([followerId, targetType, followingId])
  @@unique([followerId, targetType, airportId])
  @@unique([followerId, targetType, targetValue])
  @@index([targetType, followingId])
  @@index([targetType, airportId])
  @@index([targetType, targetValue])
  @@map("follows")
}

model Album {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  communityId  String?  @map("community_id") @db.Uuid
  title        String
  description  String?
  coverPhotoId String?  @map("cover_photo_id") @db.Uuid
  isPublic     Boolean  @default(true) @map("is_public")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  community  Community? @relation(fields: [communityId], references: [id], onDelete: SetNull)
  coverPhoto Photo?     @relation("AlbumCover", fields: [coverPhotoId], references: [id], onDelete: SetNull)
  photos     Photo[]    @relation("AlbumPhotos")
  albumPhotos AlbumPhoto[]  @relation("AlbumPhotoAlbums")
  comments   Comment[]
  likes      Like[]

  @@map("albums")
}

model Photo {
  id                   String           @id @default(uuid()) @db.Uuid
  userId               String           @map("user_id") @db.Uuid
  albumId              String?          @map("album_id") @db.Uuid
  caption              String?
  airline              String?
  airportCode          String?          @map("airport_code")
  takenAt              DateTime?        @map("taken_at")
  originalUrl          String           @map("original_url")
  originalWidth        Int?             @map("original_width")
  originalHeight       Int?             @map("original_height")
  fileSizeBytes        Int?             @map("file_size_bytes")
  mimeType             String?          @map("mime_type")
  moderationStatus     ModerationStatus @default(pending) @map("moderation_status")
  moderationLabels     Json?            @map("moderation_labels")
  moderationConfidence Float?           @map("moderation_confidence")
  likeCount            Int              @default(0) @map("like_count")
  hasActiveListing     Boolean          @default(false) @map("has_active_listing")
  license              PhotoLicense     @default(ALL_RIGHTS_RESERVED)
  watermarkEnabled     Boolean          @default(false) @map("watermark_enabled")
  aircraftId           String?          @map("aircraft_id") @db.Uuid
  photographerId       String?          @map("photographer_id") @db.Uuid
  photographerName     String?          @map("photographer_name")
  gearBody             String?          @map("gear_body")
  gearLens             String?          @map("gear_lens")
  exifData             Json?            @map("exif_data")
  photoCategoryId      String?          @map("photo_category_id") @db.Uuid
  aircraftSpecificCategoryId String?    @map("aircraft_specific_category_id") @db.Uuid
  operatorIcao         String?          @map("operator_icao")
  operatorType         OperatorType?    @map("operator_type")
  msn                  String?          @map("msn")
  manufacturingDate    String?          @map("manufacturing_date")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  album        Album?         @relation("AlbumPhotos", fields: [albumId], references: [id], onDelete: SetNull)
  albumPhotos  AlbumPhoto[]   @relation("AlbumPhotoPhotos")
  variants     PhotoVariant[]
  tags         PhotoTag[]
  location     PhotoLocation?
  comments     Comment[]
  likes        Like[]
  coverOfAlbum Album[]        @relation("AlbumCover")
  aircraft     Aircraft?      @relation(fields: [aircraftId], references: [id], onDelete: SetNull)
  photographer User?          @relation("PhotoPhotographer", fields: [photographerId], references: [id], onDelete: SetNull)
  photoCategory PhotoCategory? @relation(fields: [photoCategoryId], references: [id], onDelete: SetNull)
  aircraftSpecificCategory AircraftSpecificCategory? @relation(fields: [aircraftSpecificCategoryId], references: [id], onDelete: SetNull)
  listing             PhotoListing?
  orders             Order[]

  @@index([photoCategoryId])
  @@index([aircraftSpecificCategoryId])
  @@index([aircraftId])
  @@map("photos")
}

model PhotoVariant {
  id            String           @id @default(uuid()) @db.Uuid
  photoId       String           @map("photo_id") @db.Uuid
  variantType   PhotoVariantType @map("variant_type")
  url           String
  width         Int
  height        Int
  fileSizeBytes Int?             @map("file_size_bytes")
  createdAt     DateTime         @default(now()) @map("created_at")

  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@map("photo_variants")
}

model PhotoTag {
  id        String   @id @default(uuid()) @db.Uuid
  photoId   String   @map("photo_id") @db.Uuid
  tag       String
  createdAt DateTime @default(now()) @map("created_at")

  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@index([tag])
  @@map("photo_tags")
}

model Aircraft {
  id                 String       @id @default(uuid()) @db.Uuid
  registration       String       @unique @map("registration")
  airline            String?      @map("airline")
  msn                String?      @map("msn")
  manufacturingDate  DateTime?   @map("manufacturing_date")
  manufacturerId     String?      @map("manufacturer_id") @db.Uuid
  familyId           String?      @map("family_id") @db.Uuid
  variantId          String?      @map("variant_id") @db.Uuid
  operatorType       OperatorType? @map("operator_type")
  airlineId          String?      @map("airline_id") @db.Uuid
  status             AircraftStatus @default(active) @map("status")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  manufacturer    AircraftManufacturer? @relation("RegisteredAircraftManufacturer", fields: [manufacturerId], references: [id], onDelete: SetNull)
  family         AircraftFamily?       @relation("RegisteredAircraftFamily", fields: [familyId], references: [id], onDelete: SetNull)
  variant        AircraftVariant?      @relation("RegisteredAircraftVariant", fields: [variantId], references: [id], onDelete: SetNull)
  airlineRef     Airline?              @relation("RegisteredAirline", fields: [airlineId], references: [id], onDelete: SetNull)
  photos         Photo[]

  @@index([manufacturerId])
  @@index([familyId])
  @@index([variantId])
  @@index([airlineId])
  @@map("aircraft")
}

/// Photo location with raw and privacy-filtered coordinates.
/// The `geom` column uses PostGIS for spatial indexing — managed via raw SQL migration.
model PhotoLocation {
  id                 String              @id @default(uuid()) @db.Uuid
  photoId            String              @unique @map("photo_id") @db.Uuid
  rawLatitude        Float?              @map("raw_latitude")
  rawLongitude       Float?              @map("raw_longitude")
  displayLatitude    Float               @map("display_latitude")
  displayLongitude  Float               @map("display_longitude")
  privacyMode        LocationPrivacyMode @default(exact) @map("privacy_mode")
  airportId          String?             @map("airport_id") @db.Uuid
  spottingLocationId String?             @map("spotting_location_id") @db.Uuid
  locationType       String?             @map("location_type")
  country            String?             @map("country")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  photo            Photo             @relation(fields: [photoId], references: [id], onDelete: Cascade)
  airport          Airport?          @relation(fields: [airportId], references: [id], onDelete: SetNull)
  spottingLocation SpottingLocation? @relation(fields: [spottingLocationId], references: [id], onDelete: SetNull)

  // Note: PostGIS geometry column and spatial index added via raw SQL migration
  @@index([displayLatitude, displayLongitude])
  @@map("photo_locations")
}

model Airport {
  id        String   @id @default(uuid()) @db.Uuid
  icaoCode  String   @unique @map("icao_code")
  iataCode  String?  @unique @map("iata_code")
  name      String
  city      String?
  country   String?
  latitude  Float
  longitude Float
  createdAt DateTime @default(now()) @map("created_at")

  photoLocations    PhotoLocation[]
  spottingLocations SpottingLocation[]
  follows           Follow[]

  // Note: PostGIS geometry column and spatial index added via raw SQL migration
  @@map("airports")
}

model SpottingLocation {
  id          String   @id @default(uuid()) @db.Uuid
  airportId   String?  @map("airport_id") @db.Uuid
  name        String
  description String?
  accessNotes String?  @map("access_notes")
  latitude    Float
  longitude   Float
  createdById String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  airport        Airport?        @relation(fields: [airportId], references: [id], onDelete: SetNull)
  createdBy      User            @relation(fields: [createdById], references: [id], onDelete: Cascade)
  photoLocations PhotoLocation[]

  // Note: PostGIS geometry column and spatial index added via raw SQL migration
  @@map("spotting_locations")
}

model Comment {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  photoId         String?  @map("photo_id") @db.Uuid
  albumId         String?  @map("album_id") @db.Uuid
  parentCommentId String?  @map("parent_comment_id") @db.Uuid
  body            String
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  photo         Photo?    @relation(fields: [photoId], references: [id], onDelete: Cascade)
  album         Album?    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  parentComment Comment?  @relation("CommentThread", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies       Comment[] @relation("CommentThread")
  likes         Like[]

  @@map("comments")
}

model Like {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  photoId   String?  @map("photo_id") @db.Uuid
  albumId   String?  @map("album_id") @db.Uuid
  commentId String?  @map("comment_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  photo   Photo?   @relation(fields: [photoId], references: [id], onDelete: Cascade)
  album   Album?   @relation(fields: [albumId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, photoId])
  @@unique([userId, albumId])
  @@unique([userId, commentId])
  @@map("likes")
}

model Report {
  id          String           @id @default(uuid()) @db.Uuid
  reporterId  String           @map("reporter_id") @db.Uuid
  targetType  ReportTargetType @map("target_type")
  targetId    String           @map("target_id") @db.Uuid
  reason      ReportReason
  description String?
  status      ReportStatus     @default(open)
  reviewedBy  String?          @map("reviewed_by") @db.Uuid
  createdAt   DateTime         @default(now()) @map("created_at")
  resolvedAt  DateTime?        @map("resolved_at")

  reporter User  @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewer User? @relation("Reviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@map("reports")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  title     String
  body      String?
  data      Json?
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// ─── Phase 1b: Community Tables (schema-only, not exposed in API yet) ────────

model Community {
  id          String              @id @default(uuid()) @db.Uuid
  name        String
  slug        String              @unique
  description String?
  bannerUrl   String?             @map("banner_url")
  avatarUrl   String?             @map("avatar_url")
  category    String?
  visibility  CommunityVisibility @default(public)
  inviteCode  String?             @unique @map("invite_code")
  location    String?
  ownerId     String              @map("owner_id") @db.Uuid
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  owner        User                    @relation("CommunityOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members      CommunityMember[]
  subscription CommunitySubscription?
  albums       Album[]
  forumCategories ForumCategory[]
  events       CommunityEvent[]
  moderationLogs CommunityModerationLog[]

  @@map("communities")
}

model CommunityMember {
  id          String                @id @default(uuid()) @db.Uuid
  communityId String                @map("community_id") @db.Uuid
  userId      String                @map("user_id") @db.Uuid
  role        CommunityRole         @default(member)
  status      CommunityMemberStatus @default(active)
  joinedAt    DateTime              @default(now()) @map("joined_at")

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@map("community_members")
}

model CommunitySubscription {
  id               String        @id @default(uuid()) @db.Uuid
  communityId      String        @unique @map("community_id") @db.Uuid
  stripeSubId      String?       @map("stripe_sub_id")
  tier             CommunityTier @default(free)
  billingStatus    String?       @map("billing_status")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@map("community_subscriptions")
}

model ForumCategory {
  id          String    @id @default(uuid()) @db.Uuid
  communityId String?   @map("community_id") @db.Uuid
  name        String
  description String?
  slug        String
  position    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  community Community?    @relation(fields: [communityId], references: [id], onDelete: Cascade)
  threads   ForumThread[]

  @@unique([communityId, slug])
  @@map("forum_categories")
}

model ForumThread {
  id         String    @id @default(uuid()) @db.Uuid
  categoryId String    @map("category_id") @db.Uuid
  authorId   String    @map("author_id") @db.Uuid
  title      String
  isPinned   Boolean   @default(false) @map("is_pinned")
  isLocked   Boolean   @default(false) @map("is_locked")
  postCount  Int       @default(0) @map("post_count")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  lastPostAt DateTime  @default(now()) @map("last_post_at")

  category ForumCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  author   User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  posts    ForumPost[]

  @@index([categoryId, lastPostAt(sort: Desc)])
  @@map("forum_threads")
}

model ForumPost {
  id             String    @id @default(uuid()) @db.Uuid
  threadId       String    @map("thread_id") @db.Uuid
  authorId       String    @map("author_id") @db.Uuid
  parentPostId   String?   @map("parent_post_id") @db.Uuid
  body           String
  isDeleted      Boolean   @default(false) @map("is_deleted")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  thread     ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author     User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentPost ForumPost?  @relation("PostReplies", fields: [parentPostId], references: [id], onDelete: SetNull)
  replies    ForumPost[] @relation("PostReplies")

  @@index([threadId, createdAt])
  @@map("forum_posts")
}

model CommunityEvent {
  id          String    @id @default(uuid()) @db.Uuid
  communityId String    @map("community_id") @db.Uuid
  organizerId String    @map("organizer_id") @db.Uuid
  title       String
  description String?
  location    String?
  startsAt    DateTime  @map("starts_at")
  endsAt      DateTime? @map("ends_at")
  maxAttendees Int?     @map("max_attendees")
  coverUrl    String?   @map("cover_url")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  community  Community        @relation(fields: [communityId], references: [id], onDelete: Cascade)
  organizer  User             @relation("EventOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  attendees  EventAttendee[]

  @@index([communityId, startsAt])
  @@map("community_events")
}

model EventAttendee {
  id      String            @id @default(uuid()) @db.Uuid
  eventId String            @map("event_id") @db.Uuid
  userId  String            @map("user_id") @db.Uuid
  status  EventRsvpStatus   @default(going)
  joinedAt DateTime         @default(now()) @map("joined_at")

  event CommunityEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("event_attendees")
}

enum EventRsvpStatus {
  going
  maybe
  not_going
}

model AlbumPhoto {
  albumId  String   @map("album_id") @db.Uuid
  photoId  String   @map("photo_id") @db.Uuid
  addedAt  DateTime @default(now()) @map("added_at")

  album  Album @relation("AlbumPhotoAlbums", fields: [albumId], references: [id], onDelete: Cascade)
  photo  Photo @relation("AlbumPhotoPhotos", fields: [photoId], references: [id], onDelete: Cascade)

  @@id([albumId, photoId])
  @@index([photoId])
  @@map("album_photos")
}

enum CommunityModerationAction {
  ban
  unban
  kick
  pin_thread
  unpin_thread
  lock_thread
  unlock_thread
  delete_post
  delete_photo
  delete_comment
}

model CommunityModerationLog {
  id           String                     @id @default(uuid()) @db.Uuid
  communityId  String                     @map("community_id") @db.Uuid
  moderatorId  String                     @map("moderator_id") @db.Uuid
  targetUserId String                     @map("target_user_id") @db.Uuid
  action       CommunityModerationAction
  reason       String?
  metadata     Json?
  createdAt    DateTime                   @default(now()) @map("created_at")

  community  Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  moderator  User      @relation("Moderator", fields: [moderatorId], references: [id], onDelete: Cascade)
  targetUser User      @relation("TargetUser", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([communityId, createdAt(sort: Desc)])
  @@index([communityId, moderatorId])
  @@map("community_moderation_logs")
}

// ─── Site Settings ─────────────────────────────────────────────────────────────

model SiteSettings {
  id        String   @id @default("site_settings") @map("id")
  bannerUrl String?  @map("banner_url")
  tagline   String?  @map("tagline")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

// ─── Marketplace ─────────────────────────────────────────────────────────────

model SellerProfile {
  id                       String   @id @default(uuid()) @db.Uuid
  userId                   String   @unique @map("user_id") @db.Uuid
  stripeAccountId          String?  @unique @map("stripe_account_id")
  stripeOnboardingComplete Boolean  @default(false) @map("stripe_onboarding_complete")
  approved                 Boolean  @default(false)
  status                   SellerStatus @default(pending)
  bio                      String?
  website                  String?
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketplaceItems MarketplaceItem[]
  feedback        SellerFeedback[]

  @@map("seller_profiles")
}

model PhotoListing {
  id        String   @id @default(uuid()) @db.Uuid
  photoId   String   @unique @map("photo_id") @db.Uuid
  sellerId  String   @map("seller_id") @db.Uuid
  priceUsd  Decimal  @map("price_usd") @db.Decimal(10, 2)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  photo    Photo     @relation(fields: [photoId], references: [id], onDelete: Cascade)
  seller   User      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  orders   Order[]

  @@index([sellerId])
  @@map("photo_listings")
}

model Order {
  id                   String      @id @default(uuid()) @db.Uuid
  buyerId              String      @map("buyer_id") @db.Uuid
  sellerId             String      @map("seller_id") @db.Uuid
  photoId              String      @map("photo_id") @db.Uuid
  listingId            String      @map("listing_id") @db.Uuid
  amountUsd            Decimal     @map("amount_usd") @db.Decimal(10, 2)
  platformFeeUsd      Decimal     @map("platform_fee_usd") @db.Decimal(10, 2)
  stripePaymentIntentId String?  @unique @map("stripe_payment_intent_id")
  stripeTransferId     String?    @map("stripe_transfer_id")
  status               OrderStatus @default(pending)
  createdAt            DateTime   @default(now()) @map("created_at")

  buyer    User         @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Cascade)
  seller   User         @relation("SellerSales", fields: [sellerId], references: [id], onDelete: Cascade)
  photo    Photo       @relation(fields: [photoId], references: [id], onDelete: Cascade)
  listing  PhotoListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@map("orders")
}

// ─── Collectibles Marketplace ───────────────────────────────────────────────

model MarketplaceCategory {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  label     String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  items MarketplaceItem[]

  @@map("marketplace_categories")
}

model MarketplaceItem {
  id                 String           @id @default(uuid()) @db.Uuid
  sellerId           String           @map("seller_id") @db.Uuid
  userId             String           @map("user_id") @db.Uuid
  categoryId         String           @map("category_id") @db.Uuid
  title              String
  description        String?
  priceUsd           Decimal          @map("price_usd") @db.Decimal(10, 2)
  condition          String
  location           String?
  contactEmail       String?          @map("contact_email")
  contactPhone       String?          @map("contact_phone")
  active             Boolean          @default(false)
  moderationStatus   ModerationStatus @default(pending) @map("moderation_status")
  moderationReason   String?          @map("moderation_reason")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  seller   SellerProfile       @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  user     User               @relation("SellerItems", fields: [userId], references: [id], onDelete: Cascade)
  category MarketplaceCategory @relation(fields: [categoryId], references: [id])
  images   MarketplaceItemImage[]
  feedback SellerFeedback[]

  @@index([sellerId])
  @@index([userId])
  @@index([categoryId])
  @@index([moderationStatus])
  @@map("marketplace_items")
}

model MarketplaceItemImage {
  id            String           @id @default(uuid()) @db.Uuid
  itemId        String           @map("item_id") @db.Uuid
  variantType   PhotoVariantType @map("variant_type")
  url           String
  width         Int
  height        Int
  fileSizeBytes Int?             @map("file_size_bytes")
  sortOrder     Int              @default(0) @map("sort_order")
  createdAt     DateTime         @default(now()) @map("created_at")

  item MarketplaceItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@map("marketplace_item_images")
}

model SellerFeedback {
  id        String   @id @default(uuid()) @db.Uuid
  sellerId  String   @map("seller_id") @db.Uuid
  buyerId   String   @map("buyer_id") @db.Uuid
  rating    Int
  comment   String?
  itemId    String?  @map("item_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  seller SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  buyer  User          @relation("SellerReceivedFeedback", fields: [buyerId], references: [id], onDelete: Cascade)
  item   MarketplaceItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@unique([buyerId, sellerId])
  @@index([sellerId])
  @@map("seller_feedback")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}
