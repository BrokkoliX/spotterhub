# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://spotterspace:spotterspace_dev@localhost:5433/spotterspace

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── S3 / LocalStack ────────────────────────────────────────────────────────
S3_BUCKET=spotterspace-photos
S3_ENDPOINT=http://localhost:4566
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ─── Auth (Cognito — use mock values for local dev) ─────────────────────────
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=your-cognito-client-id
JWT_SECRET=dev-secret-do-not-use-in-production

# ─── Mapbox ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get your API key at https://resend.com — free tier available
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=SpotterSpace <noreply@spotterspace.com>
# Base URL for password reset links (default: http://localhost:3000)
WEB_BASE_URL=http://localhost:3000

# ─── API ─────────────────────────────────────────────────────────────────────
API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Environment ─────────────────────────────────────────────────────────────
NODE_ENV=development
