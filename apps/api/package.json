    "@spotterhub/db": "*",
    "@spotterhub/shared": "*",
    "cors": "^2.8.5",
    "graphql": "^16.9.0",
    "graphql-tag": "^2.12.6",
    "jsonwebtoken": "^9.0.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@spotterhub/eslint-config": "*",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.14.0",
    "@types/sharp": "^0.31.1",
    "eslint": "^8.57.0",
